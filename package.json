{
  "name": "@hax-brasil/replay-decoder",
  "version": "1.0.0",
  "description": "Node.js HBR2 decoder and validator powered by haxball-replay-decoder",
  "main": "index.js",
  "types": "index.d.ts",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hax-brasil/node-haxball-replay-decoder.git"
  },
  "license": "MIT",
  "keywords": [
    "haxball",
    "replay",
    "hbr2",
    "decoder",
    "napi-rs",
    "node-addon"
  ],
  "files": [
    "index.d.ts",
    "types.d.ts",
    "index.js",
    "README.md"
  ],
  "napi": {
    "binaryName": "replay-decoder",
    "targets": [
      "x86_64-pc-windows-msvc",
      "x86_64-apple-darwin",
      "x86_64-unknown-linux-gnu",
      "aarch64-unknown-linux-gnu",
      "aarch64-apple-darwin"
    ]
  },
  "engines": {
    "node": ">= 16"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "scripts": {
    "artifacts": "napi artifacts",
    "bench": "node --import @oxc-node/core/register benchmark/bench.ts",
    "build": "napi build --platform --release --no-js --dts native.d.ts",
    "build:debug": "napi build --platform --no-js --dts native.d.ts",
    "format": "run-p format:prettier format:rs format:toml",
    "format:prettier": "prettier . -w",
    "format:toml": "taplo format",
    "format:rs": "cargo fmt",
    "lint": "oxlint .",
    "prepublishOnly": "napi prepublish -t npm",
    "test": "pnpm typecheck && pnpm build:debug && ava",
    "typecheck": "tsc -p __test__/tsconfig.json --noEmit",
    "preversion": "napi build --platform --no-js --dts native.d.ts && git add .",
    "version": "napi version",
    "prepare": "husky"
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "@napi-rs/cli": "^3.2.0",
    "@oxc-node/core": "^0.0.35",
    "@taplo/cli": "^0.7.0",
    "ava": "^7.0.0",
    "chalk": "^5.6.2",
    "husky": "^9.1.7",
    "lint-staged": "^16.1.6",
    "npm-run-all2": "^8.0.4",
    "oxlint": "^1.14.0",
    "prettier": "^3.6.2",
    "tinybench": "^6.0.0",
    "typescript": "^5.9.2"
  },
  "lint-staged": {
    "*.@(js|ts|tsx)": [
      "oxlint --fix"
    ],
    "*.@(js|ts|tsx|yml|yaml|md|json)": [
      "prettier --write"
    ],
    "*.toml": [
      "taplo format"
    ]
  },
  "ava": {
    "extensions": {
      "ts": "module"
    },
    "timeout": "2m",
    "workerThreads": false,
    "environmentVariables": {
      "OXC_TSCONFIG_PATH": "./__test__/tsconfig.json"
    },
    "nodeArguments": [
      "--import",
      "@oxc-node/core/register"
    ]
  },
  "prettier": {
    "printWidth": 120,
    "semi": false,
    "trailingComma": "all",
    "singleQuote": true,
    "arrowParens": "always"
  },
  "packageManager": "pnpm@10.13.1"
}
